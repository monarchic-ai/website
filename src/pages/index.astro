---
import Shader14 from "../components/Shader14";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg?v=1" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Coming Soon</title>
  </head>
  <body class="min-h-screen bg-black text-white">
    <main class="relative min-h-screen overflow-hidden">
      <Shader14
        className="pointer-events-none absolute inset-0 h-full w-full"
        client:only="react"
      />
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.03),_transparent_20%),linear-gradient(to_bottom,_rgba(0,0,0,0.62),_rgba(0,0,0,0.88))]"></div>

      <section class="relative z-10 mx-auto flex min-h-screen max-w-5xl flex-col items-start justify-center px-6 py-16">
        <div class="mb-10 inline-flex items-center gap-3 border-2 border-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.35em]">
          Signal
          <span class="h-2 w-2 bg-white"></span>
        </div>

        <h1 class="text-5xl font-extrabold uppercase leading-[0.9] sm:text-7xl lg:text-8xl [text-shadow:6px_6px_0_rgba(255,255,255,0.12)]">
          Coming<br />Soon
        </h1>

        <p class="mt-6 text-sm uppercase tracking-[0.35em]">
          Intelligence is created here
        </p>

        <div class="mt-10 grid w-full gap-6 sm:grid-cols-2">
          <div class="border-2 border-white p-5">
            <p class="text-xs uppercase tracking-[0.35em]">Status</p>
            <p class="mt-3 text-lg font-semibold">Initializing</p>
          </div>
          <div class="border-2 border-white p-5">
            <p class="text-xs uppercase tracking-[0.35em]">Access</p>
            <p class="mt-3 text-lg font-semibold">Closed</p>
          </div>
        </div>

        <div class="mt-12 flex items-center gap-4 border-2 border-white px-5 py-3 text-xs uppercase tracking-[0.4em]">
          <span class="block h-2 w-2 bg-white"></span>
          <span>Stand by</span>
        </div>
      </section>
    </main>
  </body>
</html>
