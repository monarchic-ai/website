---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Coming Soon</title>
  </head>
  <body class="min-h-screen bg-black text-white">
    <main class="relative min-h-screen overflow-hidden">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 opacity-20 [background-image:linear-gradient(transparent_95%,_rgba(255,255,255,0.22)_95%),linear-gradient(90deg,transparent_95%,_rgba(255,255,255,0.22)_95%)] [background-size:120px_120px]"></div>
        <div class="absolute inset-[-10%] opacity-15 mix-blend-screen [background-image:repeating-linear-gradient(0deg,rgba(255,255,255,0.04)_0_1px,transparent_1px_3px),repeating-linear-gradient(90deg,rgba(255,255,255,0.04)_0_1px,transparent_1px_4px)]"></div>
      </div>

      <section class="relative z-10 mx-auto flex min-h-screen max-w-5xl flex-col items-start justify-center px-6 py-16">
        <div class="mb-10 inline-flex items-center gap-3 border-2 border-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.35em]">
          Signal
          <span class="h-2 w-2 bg-white"></span>
        </div>

        <h1 class="text-5xl font-extrabold uppercase leading-[0.9] sm:text-7xl lg:text-8xl [text-shadow:6px_6px_0_rgba(255,255,255,0.12)]">
          Coming<br />Soon
        </h1>

        <p class="mt-6 text-sm uppercase tracking-[0.35em]">
          Intelligence is created here
        </p>

        <div class="mt-10 grid w-full gap-6 sm:grid-cols-2">
          <div class="border-2 border-white p-5">
            <p class="text-xs uppercase tracking-[0.35em]">Status</p>
            <p class="mt-3 text-lg font-semibold">Initializing</p>
          </div>
          <div class="border-2 border-white p-5">
            <p class="text-xs uppercase tracking-[0.35em]">Access</p>
            <p class="mt-3 text-lg font-semibold">Closed</p>
          </div>
        </div>

        <div class="mt-12 flex items-center gap-4 border-2 border-white px-5 py-3 text-xs uppercase tracking-[0.4em]">
          <span class="block h-2 w-2 bg-white"></span>
          <span>Stand by</span>
        </div>
      </section>

      <div class="pointer-events-none absolute inset-0 z-30">
        <div class="absolute inset-[-5%] opacity-35 mix-blend-soft-light [background-image:radial-gradient(rgba(255,255,255,0.22)_1.4px,transparent_1.5px),radial-gradient(rgba(255,255,255,0.16)_1.2px,transparent_1.3px),radial-gradient(rgba(255,255,255,0.1)_1px,transparent_1.1px)] [background-size:7px_7px,9px_9px,12px_12px] [background-position:0_0,3px_2px,5px_1px] animate-[brutal-static_0.55s_steps(2,end)_infinite]"></div>
      </div>
    </main>
  </body>
</html>
